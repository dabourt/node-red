        "format": "<div class=\"status-card\">\n    <div class=\"status-header\">\n        <div>\n            <div class=\"status-label\">Shared event log</div>\n            <div class=\"status-title\">All alerts saved for everyone</div>\n        </div>\n    </div>\n    <div class=\"inner-log-header\">\n        <div>\n            <div class=\"inner-log-title\">Saved events</div>\n            <div class=\"inner-log-subtitle\">Shared across all dashboard users</div>\n        </div>\n    </div>\n    <div class=\"inner-log-list\" ng-if=\"sharedLogs.length\">\n        <div class=\"inner-log-item\" ng-repeat=\"entry in sharedLogs\">\n            <span class=\"inner-log-tag\">{{entry.sensor}}</span>\n            <div class=\"inner-log-body\">\n                <div class=\"inner-log-summary\">{{entry.summary}}</div>\n                <div class=\"inner-log-time\">{{entry.time}}</div>\n            </div>\n        </div>\n    </div>\n    <div class=\"inner-log-empty\" ng-if=\"!sharedLogs.length\">No shared logs yet.</div>\n</div>\n<script>\n(function(scope) {\n    scope.sharedLogs = scope.sharedLogs || [];\n    scope.$watch('msg', function(msg) {\n        if (!msg) return;\n        scope.sharedLogs = msg.allLogs || scope.sharedLogs || [];\n    });\n})(scope);\n</script>\n<style>\n.status-card{font-family:Arial,Helvetica,sans-serif;text-align:left;padding:16px 18px;border-radius:18px;background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(245,245,255,0.96));box-shadow: 0 18px 35px rgba(0,0,0,0.08);border:1px solid rgba(0,0,0,0.06);}\n.status-header{display:flex;align-items:center;gap:14px;margin-bottom:14px;}\n.status-label{font-size:11px;text-transform:uppercase;color:#888;letter-spacing:0.12em;margin-bottom:4px;}\n.status-title{font-size:18px;font-weight:700;color:#222;margin:0;}\n.inner-log-header{margin-bottom:14px;}\n.inner-log-title{font-size:15px;font-weight:700;color:#222;}\n.inner-log-subtitle{font-size:12px;color:#666;}\n.inner-log-list{display:grid;gap:10px;}\n.inner-log-item{display:grid;grid-template-columns:auto 1fr;gap:10px;align-items:start;padding:12px 14px;border-radius:14px;background:#fdf8f0;border:1px solid rgba(255,126,0,0.18);}\n.inner-log-tag{display:inline-flex;align-items:center;padding:4px 10px;border-radius:999px;background:#fff4e5;color:#b96f1b;font-size:12px;font-weight:700;}\n.inner-log-summary{font-size:13px;color:#333;line-height:1.4;}\n.inner-log-time{font-size:11px;color:#777;white-space:nowrap;}\n.inner-log-empty{font-size:13px;color:#777;padding:18px 0;text-align:center;}\n</style>",
