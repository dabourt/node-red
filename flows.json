    {
        "id": "2fccb139.f0ea9e",
        "type": "function",
        "z": "82dcc1e4.e015c",
        "name": "",
        "func": "let status = msg.payload.toString();\nlet summary = status;\nlet log = false;\n\nif (status.includes(\"Earthquake detected!\")) {\n    msg.status = \"Earthquake ALERT\";\n    msg.color = \"red\";\n    summary = \"Earthquake detected!\";\n    log = true;\n} else if (status.includes(\"No Earthquake!\")) {\n    msg.status = \"Earthquake OK\";\n    msg.color = \"green\";\n    summary = \"No earthquake.\";\n} else if (status.includes(\"Fire detected!\")) {\n    msg.status = \"Fire ALERT\";\n    msg.color = \"red\";\n    summary = \"Fire detected!\";\n    log = true;\n} else if (status.includes(\"No Fire!\")) {\n    msg.status = \"Fire OK\";\n    msg.color = \"green\";\n    summary = \"No fire.\";\n} else {\n    msg.status = \"Unknown status\";\n    msg.color = \"gray\";\n    summary = status;\n}\n\nmsg.summary = summary;\nmsg.log = log;\nmsg.eventType = (msg.status && msg.status.indexOf('Earthquake') !== -1) ? 'Earthquake' : (msg.status && msg.status.indexOf('Fire') !== -1) ? 'Fire' : 'General';\n\nlet allLogs = global.get('allLogs') || [];\nif (msg.log && msg.eventType !== 'General') {\n    allLogs.unshift({\n        time: (new Date()).toLocaleString(),\n        sensor: msg.eventType,\n        status: msg.status,\n        summary: msg.summary\n    });\n    if (allLogs.length > 100) { allLogs.length = 100; }\n    global.set('allLogs', allLogs);\n}\nmsg.allLogs = allLogs;\nreturn msg;",
