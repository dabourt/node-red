    {
        "id": "b8b5794e.3ab598",
        "type": "ui_template",
        "z": "82dcc1e4.e015c",
        "group": "747d060d.8e3a38",
        "name": "earthquake_templete",
        "order": 0,
        "width": "0",
        "height": "0",
        "format": "<div class=\"status-card\">\n    <div class=\"status-header\">\n        <div class=\"status-icon\" style=\"background: {{msg.color}}; box-shadow: 0 0 22px rgba(0,0,0,0.12);\"></div>\n        <span class=\"status-led\" ng-class=\"{active: ledBlink}\"></span>\n        <div>\n            <div class=\"status-label\">Live status</div>\n            <div class=\"status-title\">{{msg.status}}</div>\n        </div>\n    </div>\n    <div class=\"status-summary\">{{msg.summary}}</div>\n    <div class=\"status-footer\">\n        <span class=\"status-chip\" style=\"background: {{msg.color}}22; color: {{msg.color}}; border: 1px solid {{msg.color}};\">Realtime</span>\n        <span class=\"status-note\">Updated automatically</span>\n    </div>\n</div>\n<div class=\"inner-log-card\">\n    <div class=\"inner-log-header\">\n        <div>\n            <div class=\"inner-log-title\">Earthquake log</div>\n            <div class=\"inner-log-subtitle\">Latest alerts for the earthquake sensor</div>\n        </div>\n        <button class=\"inner-log-clear\" ng-click=\"clearEarthquakeLog()\">Clear</button>\n    </div>\n    <div class=\"inner-log-list\" ng-if=\"eqLogs.length\">\n        <div class=\"inner-log-item\" ng-repeat=\"entry in eqLogs\">\n            <span class=\"inner-log-tag\">Alert</span>\n            <div class=\"inner-log-summary\">{{entry.summary}}</div>\n            <div class=\"inner-log-time\">{{entry.time}}</div>\n        </div>\n    </div>\n    <div class=\"inner-log-empty\" ng-if=\"!eqLogs.length\">No earthquake alerts yet.</div>\n</div>\n<script>\n(function(scope) {\n    scope.eqLogs = scope.eqLogs || [];\n    scope.ledBlink = false;\n    scope.clearEarthquakeLog = function() { scope.eqLogs = []; };\n    function blinkEarthquakeLed() {\n        scope.ledBlink = true;\n        if (!scope.$$phase) { scope.$apply(); }\n        setTimeout(function() {\n            scope.ledBlink = false;\n            if (!scope.$$phase) { scope.$apply(); }\n        }, 600);\n    }\n    scope.$watch('msg', function(msg) {\n        if (!msg) return;\n        blinkEarthquakeLed();\n        if (!msg.log || msg.eventType !== 'Earthquake') return;\n        scope.eqLogs.unshift({\n            time: (new Date()).toLocaleTimeString(),\n            summary: msg.summary || 'Earthquake detected!'\n        });\n        if (scope.eqLogs.length > 5) { scope.eqLogs.pop(); }\n    });\n})(scope);\n</script>\n<style>\n.status-card{font-family:Arial,Helvetica,sans-serif;text-align:left;padding:16px 18px;border-radius:18px;background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(245,245,255,0.96));box-shadow: 0 18px 35px rgba(0,0,0,0.08);border:1px solid rgba(0,0,0,0.06);}\n.status-header{display:flex;align-items:center;gap:14px;margin-bottom:14px;}\n.status-icon{width:44px;height:44px;border-radius:50%;border:2px solid #fff;}\n.status-led{width:12px;height:12px;border-radius:50%;background:#ccc;border:1px solid rgba(0,0,0,0.08);box-shadow: inset 0 0 0 rgba(255,255,255,0.6);transition: transform 0.2s ease, background 0.2s ease;}\n.status-led.active{background:#ff3b30;box-shadow: 0 0 12px rgba(255,59,48,0.6);transform: scale(1.15);animation: blinkPulse 0.6s ease-in-out;}\n@keyframes blinkPulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.25);opacity:0.65;}}\n.status-label{font-size:11px;text-transform:uppercase;color:#888;letter-spacing:0.12em;margin-bottom:4px;}\n.status-title{font-size:20px;font-weight:700;color:#222;margin:0;}\n.status-summary{font-size:14px;color:#525252;line-height:1.7;padding-left:2px;}\n.status-footer{display:flex;justify-content:space-between;align-items:center;margin-top:18px;gap:14px;flex-wrap:wrap;}\n.status-chip{display:inline-flex;align-items:center;padding:6px 12px;border-radius:999px;font-size:12px;font-weight:700;}\n.status-note{font-size:12px;color:#777;}\n.inner-log-card{margin-top:16px;padding:16px;border-radius:18px;background:#ffffff;border:1px solid rgba(0,0,0,0.06);box-shadow:0 12px 24px rgba(0,0,0,0.05);}\n.inner-log-header{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;}\n.inner-log-title{font-size:15px;font-weight:700;color:#222;}\n.inner-log-subtitle{font-size:12px;color:#666;}\n.inner-log-clear{padding:8px 16px;border:none;border-radius:999px;background:#0094CE;color:#fff;font-weight:700;cursor:pointer;}\n.inner-log-list{display:grid;gap:10px;}\n.inner-log-item{display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;padding:12px 14px;border-radius:14px;background:#f5f9ff;border:1px solid rgba(0,148,206,0.16);}\n.inner-log-tag{display:inline-flex;align-items:center;padding:4px 10px;border-radius:999px;background:#ffe7e7;color:#b53d3d;font-size:12px;font-weight:700;}\n.inner-log-summary{font-size:13px;color:#333;line-height:1.4;}\n.inner-log-time{font-size:11px;color:#777;white-space:nowrap;}\n.inner-log-empty{font-size:13px;color:#777;padding:18px 0;text-align:center;}\n</style>",
